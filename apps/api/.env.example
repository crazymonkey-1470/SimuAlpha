# SimuAlpha API Environment Configuration
# Copy this file to .env and adjust values as needed

# Database (PostgreSQL) — use Supabase connection string in production
SIMUALPHA_DATABASE_URL=postgresql://simualpha:simualpha@localhost:5432/simualpha

# Debug mode — false in production
SIMUALPHA_DEBUG=false

# CORS origins — add your production frontend URL
# SIMUALPHA_CORS_ORIGINS=["https://simualpha.com","http://localhost:3000"]

# JWT authentication — REQUIRED in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SIMUALPHA_JWT_SECRET=change-me-in-production

# Financial data provider API key (e.g. Financial Modeling Prep)
# Leave empty to use mock data
SIMUALPHA_FINANCIAL_DATA_API_KEY=

# Report cache TTL in seconds (default: 21600 = 6 hours)
SIMUALPHA_REPORT_CACHE_TTL=21600
