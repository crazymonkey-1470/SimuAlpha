# SimuAlpha API Environment Configuration
# Copy this file to .env and adjust values as needed

# Database (PostgreSQL)
SIMUALPHA_DATABASE_URL=postgresql://simualpha:simualpha@localhost:5432/simualpha

# Redis (for job queue integration)
SIMUALPHA_REDIS_URL=redis://localhost:6379/0

# Debug mode
SIMUALPHA_DEBUG=false

# CORS origins (comma-separated in env, but set via Settings default)
# SIMUALPHA_CORS_ORIGINS=["http://localhost:3000"]

# JWT authentication
# IMPORTANT: Set a strong, unique secret in production
SIMUALPHA_JWT_SECRET=change-me-in-production-use-a-random-64-char-string
SIMUALPHA_ACCESS_TOKEN_EXPIRE_MINUTES=60
SIMUALPHA_REFRESH_TOKEN_EXPIRE_DAYS=30

# Use real market data from Yahoo Finance (default: false = synthetic)
SIMUALPHA_USE_REAL_DATA=false

# Simulation cache TTL in seconds (default: 300 = 5 minutes)
SIMUALPHA_SIM_CACHE_TTL=300
