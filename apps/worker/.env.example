# SimuAlpha Worker Configuration
# Copy this to .env and adjust as needed.

ENVIRONMENT=development
LOG_LEVEL=INFO

# Output mode: "log" prints to stdout, "json" writes JSON files to OUTPUT_DIR
OUTPUT_MODE=log
OUTPUT_DIR=./output

# Simulation model version (informational)
MODEL_VERSION=sa-sim-0.4.2

# Redis URL for job queue (optional, not required for local dev)
# REDIS_URL=redis://localhost:6379/0

# API base URL for callbacks (optional, not required for local dev)
# API_BASE_URL=http://localhost:8000

# Seed for deterministic generation (set to fixed int for reproducibility)
# SEED=42
