# SimuAlpha Worker Configuration
# Copy this to .env and adjust as needed.

SIMUALPHA_ENVIRONMENT=development
SIMUALPHA_LOG_LEVEL=INFO

# Output mode: "log" prints to stdout, "json" writes JSON files to OUTPUT_DIR
SIMUALPHA_OUTPUT_MODE=log
SIMUALPHA_OUTPUT_DIR=./output

# Simulation model version (informational)
SIMUALPHA_MODEL_VERSION=sa-sim-0.4.2

# Database (PostgreSQL) — same instance as the API
SIMUALPHA_DATABASE_URL=postgresql://simualpha:simualpha@localhost:5432/simualpha

# Redis URL for job queue
SIMUALPHA_REDIS_URL=redis://localhost:6379/0

# API base URL for callbacks (optional, not required for local dev)
# SIMUALPHA_API_BASE_URL=http://localhost:8000

# Seed for deterministic generation (set to fixed int for reproducibility)
# SIMUALPHA_SEED=42
