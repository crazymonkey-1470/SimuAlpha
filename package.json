{
  "name": "simualpha",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "dev:web": "turbo dev --filter=@simualpha/web",
    "build:web": "turbo build --filter=@simualpha/web",
    "lint:web": "turbo lint --filter=@simualpha/web",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3"
  }
}
