# OpenBB Platform personal access token
OPENBB_PAT=

# Supabase project + service-role key (read/write to cache tables)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Anthropic API key — NOT used by this service directly. Present because
# the root .env pattern in the monorepo ships one; reserved for downstream
# tools that may be added to the registry in future stages.
ANTHROPIC_API_KEY=

# Break-glass auth for the HTTP API. If set, a raw Bearer equality match
# against this value authorizes requests WITHOUT touching Supabase
# api_keys — a WARNING is logged every time it fires. Leave unset in
# production once scoped api_keys rows exist for each caller.
QUANT_SERVICE_BOOTSTRAP_TOKEN=
