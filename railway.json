{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm ci",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "startCommand": "cd backend && node server.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
