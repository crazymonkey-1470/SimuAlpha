# ═══════════════════════════════════════════════════════════════
# SimuAlpha — environment variable template
# ═══════════════════════════════════════════════════════════════
# Copy to .env for local dev; set these in the Railway dashboard
# for production (NEVER commit real secrets to git).
# ═══════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Public origin, used for CORS allowlist.
FRONTEND_URL=https://simualpha.com

# ── PostgreSQL / Supabase ─────────────────────────────────────
# Full Postgres connection URL. For Supabase, use the *pooled*
# connection string (port 6543) for the app. Migrations run via
# the direct connection (DATABASE_MIGRATE_URL) when provided.
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:6543/postgres
DATABASE_MIGRATE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
DATABASE_POOL_MAX=10
# Set to "disable" only for local Postgres without TLS.
# DATABASE_SSL=disable

# Supabase client (used by existing services/supabase.js for CRUD).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...change_me...

# If you ever need to skip migrations in an emergency (dev only):
# MIGRATIONS_REQUIRED=false

# ── Admin ─────────────────────────────────────────────────────
# Random 32+ char secret. Used by tier_routes.js admin endpoints
# and the /admin dashboard. Generate with: openssl rand -hex 32
ADMIN_API_KEY=change_me_random_hex

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxx_change_me
# EMAIL_FROM=noreply@simualpha.com  # optional, defaults set in email_service.js

# ── AI + external APIs (optional; only needed for those features) ──
ANTHROPIC_API_KEY=
X_BEARER_TOKEN=
POLYGON_API_KEY=
SCRAPER_URL=http://localhost:8000
