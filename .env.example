# SimuAlpha Environment Configuration
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection URL. Falls back to local SQLite if unreachable.
SIMUALPHA_DATABASE_URL=postgresql://simualpha:simualpha@localhost:5432/simualpha

# ── Redis (Job Queue) ────────────────────────────────────────────────────
# Redis URL for RQ job queue. Simulation jobs run in-process if unavailable.
SIMUALPHA_REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SIMUALPHA_JWT_SECRET=

# ── Feature Flags ────────────────────────────────────────────────────────
# Use real Yahoo Finance data (true) or synthetic/seed data (false)
SIMUALPHA_USE_REAL_DATA=false

# Enable debug mode (verbose SQL logging, etc.)
SIMUALPHA_DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────
# Allowed origins for the API (JSON array)
SIMUALPHA_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Frontend ──────────────────────────────────────────────────────────────
# API URL for the frontend (used at build time for static export)
NEXT_PUBLIC_API_URL=http://localhost:8000
